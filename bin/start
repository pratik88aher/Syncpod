#!/usr/bin/env bash
# Simple launcher script to allow: start syncpod | start syncpod stop | start syncpod status | start syncpod restart

PROJECT_DIR="/Users/pratikaher/Syncpod"
PYTHON="$PROJECT_DIR/.venv/bin/python"
LOG_OUT="/tmp/syncpod.out.log"
LOG_ERR="/tmp/syncpod.err.log"
PIDFILE="/tmp/syncpod.pid"

if [ -z "$1" ]; then
  echo "Usage: start syncpod [start|stop|status|restart]"
  exit 2
fi

SERVICE="$1"
CMD="${2:-start}"

if [ "$SERVICE" != "syncpod" ]; then
  echo "Unknown service: $SERVICE"
  exit 2
fi

cd "$PROJECT_DIR" || { echo "Project dir not found: $PROJECT_DIR"; exit 2; }

is_running() {
  if [ -f "$PIDFILE" ]; then
    pid=$(cat "$PIDFILE" 2>/dev/null)
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi
  return 1
}

case "$CMD" in
  start)
    if is_running; then
      echo "syncpod already running (pid $(cat $PIDFILE))"
      exit 0
    fi
    if [ ! -x "$PYTHON" ]; then
      echo "Python executable not found in venv: $PYTHON"
      echo "Trying system python..."
      PYTHON="$(command -v python3 || command -v python)"
      if [ -z "$PYTHON" ]; then
        echo "No python found. Activate venv or install Python."; exit 1
      fi
    fi
    nohup "$PYTHON" "$PROJECT_DIR/main.py" > "$LOG_OUT" 2> "$LOG_ERR" &
    echo $! > "$PIDFILE"
    sleep 0.2
    echo "syncpod started (pid $(cat $PIDFILE))"
    ;;
  stop)
    if ! is_running; then
      echo "syncpod is not running"
      [ -f "$PIDFILE" ] && rm -f "$PIDFILE"
      exit 0
    fi
    pid=$(cat "$PIDFILE")
    kill "$pid" && echo "syncpod stopped" || echo "Failed to stop syncpod"
    rm -f "$PIDFILE"
    ;;
  status)
    if is_running; then
      echo "syncpod running (pid $(cat $PIDFILE))"
      exit 0
    else
      echo "syncpod not running"
      exit 1
    fi
    ;;
  restart)
    "$0" syncpod stop
    sleep 0.5
    "$0" syncpod start
    ;;
  *)
    echo "Unknown command: $CMD"
    echo "Usage: start syncpod [start|stop|status|restart]"
    exit 2
    ;;
esac
